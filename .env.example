# Seafile Docker Environment Variables
# Copy this file to .env and customize for your environment

# === Volume Directories ===
SEAFILE_VOLUME=/volume1/docker/seafile/seafile-data
SEAFILE_MYSQL_VOLUME=/volume1/docker/seafile/mysql
SEAFILE_ELASTICSEARCH_VOLUME=/volume1/docker/seafile/elasticsearch

# === MySQL Configuration ===
# Root password for MySQL (only required on first deployment)
INIT_SEAFILE_MYSQL_ROOT_PASSWORD=changeme_mysql_root_password

# MySQL Database Configuration
SEAFILE_MYSQL_DB_HOST=db
SEAFILE_MYSQL_DB_PORT=3306
SEAFILE_MYSQL_DB_USER=seafile
SEAFILE_MYSQL_DB_PASSWORD=changeme_mysql_seafile_password
SEAFILE_MYSQL_DB_CCNET_DB_NAME=ccnet_db
SEAFILE_MYSQL_DB_SEAFILE_DB_NAME=seafile_db
SEAFILE_MYSQL_DB_SEAHUB_DB_NAME=seahub_db

# === Seafile Server Configuration ===
# JWT Private Key - Generate with: pwgen -s 40 1
# REQUIRED: A random string with a length of no less than 32 characters
JWT_PRIVATE_KEY=changeme_generate_random_string_40_chars

# Server hostname or domain (REQUIRED)
# Change this to your actual domain
SEAFILE_SERVER_HOSTNAME=seafile.shojinas.home.shoji.me

# Server protocol (http or https)
# Use http when behind Traefik reverse proxy
SEAFILE_SERVER_PROTOCOL=http

# === Cache Configuration ===
# Cache provider: redis (recommended) or memcached
CACHE_PROVIDER=redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# === Time Zone ===
TIME_ZONE=America/Toronto

# === Notification Server ===
# Enable (true) or disable (false) notification feature
ENABLE_NOTIFICATION_SERVER=false
NOTIFICATION_SERVER_URL=

# === Admin Account (First Deploy) ===
# Initial admin username and password
INIT_SEAFILE_ADMIN_EMAIL=admin@example.com
INIT_SEAFILE_ADMIN_PASSWORD=changeme_admin_password

# === Advanced Settings ===
# Run Seafile container without a root user
NON_ROOT=false

# Maximum number of files for metadata feature
MD_FILE_COUNT_LIMIT=100000

# === User/Group IDs ===
PUID=1027
PGID=100
